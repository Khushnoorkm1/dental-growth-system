# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/dental_growth

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here
JWT_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# SendGrid (Email)
SENDGRID_API_KEY=SG.your-sendgrid-api-key
FROM_EMAIL=hello@yourdentalclinic.com
FROM_NAME=Smile Studio Dental

# Google Calendar
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/booking/oauth/callback
GOOGLE_CALENDAR_ID=your-calendar-id@gmail.com

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Admin
ADMIN_EMAIL=admin@yourdentalclinic.com
ADMIN_PASSWORD=Admin@Dental2024!

# Clinic Info
CLINIC_NAME=Smile Studio Dental
CLINIC_PHONE=+44 20 7123 4567
CLINIC_ADDRESS=123 Harley Street, London W1G 7HF
BOOKING_LINK=https://yourdentalclinic.com/book
